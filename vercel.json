{
  "version": 2,
  "builds": [
    {
      "src": "AlertNotification/package.json",
      "use": "@vercel/angular"
    },
    {
      "src": "server/src/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "handle": "filesystem" },

    {
      "src": "/api/(.*)",
      "dest": "server/src/server.js"
    },

    {
      "src": "/.*",
      "dest": "/index.html"
    }
  ]
}