{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist/alert-notification" }
    }
  ],
 "routes": [
  { "src": "/sw.js", "dest": "/assets/sw.js" },
  { "handle": "filesystem" },
  { "src": "/.*", "dest": "/index.html" }
]
}